{
  "name": "catapultar",
  "description": "Interface for the Catapultar Smart Account ",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist/",
    "prebuild": "bun run clean",
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json -w",
    "prepare": "cd .. && husky typescript/.husky",
    "lint:staged": "prettier -w",
    "prepublishOnly": "bun run build",
    "test": "bun test --preload ./test/setup.ts",
    "test:watch": "bun run test --watch",
    "coverage": "bun run test --coverage",
    "coverage:lcov": "bun run coverage --coverage-reporter='lcov' --coverage-dir='./'"
  },
  "lint-staged": {
    "*.ts": [
      "bun run lint:staged"
    ]
  },
  "dependencies": {
    "ox": "^0.10.6",
    "viem": "^2.43.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun": "^1.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prool": "^0.2.2",
    "typescript": "^5.9.3"
  }
}
