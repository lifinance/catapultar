{
  "name": "catapultar",
  "description": "Interface for the Catapultar Smart Account",
  "version": "0.2.1",
  "license": "LGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifinance/catapultar.git"
  },
  "bugs": {
    "url": "https://github.com/lifinance/catapultar/issues"
  },
  "homepage": "https://github.com/lifinance/catapultar#readme",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.5"
  },
  "main": "./_cjs/index.js",
  "module": "./_esm/index.js",
  "types": "./_types/index.d.ts",
  "typings": "./_types/index.d.ts",
  "files": [
    "_cjs",
    "_esm",
    "_types",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.bench.ts"
  ],
  "exports": {
    ".": {
      "types": "./_types/index.d.ts",
      "node": "./_cjs/index.js",
      "import": "./_esm/index.js",
      "require": "./_cjs/index.js",
      "default": "./_cjs/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf _cjs _esm _types dist out",
    "prebuild": "bun run clean",
    "build:js": "rollup -c",
    "build:types": "tsc --project tsconfig.build.json",
    "build:markers": "node ./scripts/write-subdir-markers.mjs",
    "build:smoke": "node ./scripts/smoke.mjs",
    "build": "bun run build:js && bun run build:types && bun run build:markers && bun run build:smoke",
    "lint:staged": "prettier -w",
    "prepublishOnly": "bun run build && bun run test",
    "test": "bun test --preload ./test/setup.ts",
    "test:watch": "bun run test --watch",
    "coverage": "bun run test --coverage",
    "coverage:lcov": "bun run coverage --coverage-reporter='lcov' --coverage-dir='./'"
  },
  "lint-staged": {
    "*.ts": [
      "bun run lint:staged"
    ]
  },
  "dependencies": {
    "ox": "^0.10.6",
    "viem": "^2.54.2"
  },
  "overrides": {
    "axios": "1.18.1",
    "esbuild": "0.28.1",
    "follow-redirects": "1.16.0",
    "form-data": "4.0.6",
    "picomatch": "4.0.5",
    "tar": "7.5.19",
    "ws": "8.21.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@lifi/tron-devkit": "^1.0.1",
    "@types/bun": "^1.3.14",
    "bun": "^1.3.14",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "prool": "^0.2.4",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.9.3"
  }
}
